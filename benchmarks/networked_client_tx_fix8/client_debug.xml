<?xml version="1.0" encoding="UTF-8"?>
<fix8>
    <default
        active="true"
        role="initiator"
        sender_comp_id="CLIENT1"
        target_comp_id="EXECUTOR"
        default_appl_ver_id="7"
        heartbeat_interval="60"
        tcp_nodelay="true"
        tcp_keepalive="false"
        ip="192.168.10.100"
        process_model="threaded"
        session_log="session_log_file"
        protocol_log="protocol_log_file"
    />

    <session
        name="CLIENT"
        active="true"
        role="initiator"
        sender_comp_id="CLIENT1"
        target_comp_id="EXECUTOR"
        default_appl_ver_id="7"
        heartbeat_interval="60"
        port="5001"
        persist="FILE"
    />

    <persist name="FILE" type="file" dir="stores" />
    <log name="session_log_file"
        type="session"
        filename="logs/session.log"
        rotation="5"
        levels="debug|info|warn|error|fatal"
        flags="sequence|timestamp|sstart|thread|location|level"
    />
    <log name="protocol_log_file"
        type="protocol"
        filename="logs/protocol.log"
        rotation="5"
        levels="debug|info|warn|error|fatal"
        flags="append|inbound|outbound"
    />
</fix8>
